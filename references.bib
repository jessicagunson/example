@article{waittEvidenceRhesusMacaques2003,
  title = {Evidence from Rhesus Macaques Suggests That Male Coloration Plays a Role in Female Primate Mate Choice},
  author = {Waitt, Corri and Little, Anthony C. and Wolfensohn, Sarah and Honess, Paul and Brown, Anthony P. and {Buchanan-Smith}, Hannah M. and Perrett, David I.},
  year = 2003,
